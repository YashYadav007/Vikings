PORT=4000
NODE_ENV=development

USE_MOCK_LLM=true
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=openai
CODING_AGENT_PROVIDER=mock
CODING_AGENT_MODEL=gemini-2.5-flash-lite
CLAUDE_CODE_ENABLED=false
CLAUDE_CODE_COMMAND=claude

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=1536

RAG_PROVIDER=local
RAG_FALLBACK_MODE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=public

MEMORY_PROVIDER=local
HINDSIGHT_API_URL=
HINDSIGHT_API_KEY=
HINDSIGHT_PROJECT_PREFIX=devcontext
HINDSIGHT_DEMO_SESSION_ID=
HINDSIGHT_FALLBACK_MODE=local

GITHUB_TOKEN=
MOCK_GITHUB_WRITE=true
TEST_GITHUB_REPO=

DISABLE_AUTO_REINDEX=true
MAX_EMBEDDING_FILES_PER_IMPORT=40
MAX_EMBEDDING_CHUNKS_PER_IMPORT=200
MAX_AGENT_CONTEXT_CHUNKS=8
